<h1 style="margin-bottom: 10px;">Listings Management</h1>

<p style="color: #666;">Approve or reject user submissions with full details</p>

<a href="/admin/dashboard" style="display:inline-block; margin-bottom: 15px;">
  ⬅ Back to Dashboard
</a>

<hr />

<!-- FILTER BAR -->
<form method="GET" action="/admin/listings" style="margin: 15px 0;">
  <select name="status" style="padding: 6px;">
    <option value="">All</option>
    <option value="pending" <%= status === "pending" ? "selected" : "" %>>Pending</option>
    <option value="approved" <%= status === "approved" ? "selected" : "" %>>Approved</option>
    <option value="rejected" <%= status === "rejected" ? "selected" : "" %>>Rejected</option>
  </select>

  <button type="submit" style="padding: 6px 10px; cursor: pointer;">
    Filter
  </button>
</form>

<hr />

<!-- GRID -->
<div style="
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
  gap: 15px;
">

  <% if (listings.length === 0) { %>
    <p>No listings found.</p>
  <% } %>

  <% listings.forEach(listing => { %>

    <div style="
      border: 1px solid #e5e5e5;
      border-radius: 12px;
      padding: 12px;
      background: #fff;
      box-shadow: 0 2px 8px rgba(0,0,0,0.05);
    ">

      <!-- IMAGE -->
      <% if (listing.image && listing.image.url) { %>
        <img 
          src="<%= listing.image.url %>" 
          style="width:100%; height:180px; object-fit:cover; border-radius:10px;"
        />
      <% } %>

      <!-- TITLE -->
      <h3 style="margin: 10px 0 5px;"><%= listing.title %></h3>

      <!-- DESCRIPTION -->
      <p style="color:#666; font-size:14px;">
        <%= listing.description ? listing.description.substring(0, 120) + "..." : "No description" %>
      </p>

      <!-- DETAILS -->
      <div style="font-size:14px; color:#444; line-height:1.6;">
        <p>💰 Price: ₹<%= listing.price || "N/A" %></p>
        <p>📍 Location: <%= listing.location %></p>
        <p>🌍 Country: <%= listing.country %></p>
        <p>📂 Category: <%= listing.category %></p>
        <p>👤 Owner: <%= listing.owner?.username || "Unknown" %></p>
      </div>

      <!-- STATUS -->
      <p style="margin: 8px 0;">
        <% if (listing.status === "pending") { %>
          <span style="background:#facc15; padding:4px 8px; border-radius:6px;">Pending</span>
        <% } else if (listing.status === "approved") { %>
          <span style="background:#22c55e; color:white; padding:4px 8px; border-radius:6px;">Approved</span>
        <% } else { %>
          <span style="background:#ef4444; color:white; padding:4px 8px; border-radius:6px;">Rejected</span>
        <% } %>
      </p>

      <!-- ACTIONS -->
      <div style="display:flex; gap:8px; margin-top:10px;">

        <% if (listing.status !== "approved") { %>
          <form method="POST" action="/admin/listings/<%= listing._id %>/approve">
            <input type="hidden" name="redirectUrl" value="/admin/listings?status=<%= status || '' %>">

            <button style="
              background:#22c55e;
              color:white;
              border:none;
              padding:6px 10px;
              border-radius:6px;
              cursor:pointer;
            ">
              Approve
            </button>
          </form>
        <% } %>

        <% if (listing.status !== "rejected") { %>
          <form method="POST" action="/admin/listings/<%= listing._id %>/reject">
            <input type="hidden" name="redirectUrl" value="/admin/listings?status=<%= status || '' %>">

            <button style="
              background:#ef4444;
              color:white;
              border:none;
              padding:6px 10px;
              border-radius:6px;
              cursor:pointer;
            ">
              Reject
            </button>
          </form>
        <% } %>

      </div>

    </div>

  <% }) %>

</div>