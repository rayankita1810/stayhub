<% layout("layouts/boilerplate") %>

<div class="container mt-4">

  <!-- PAGE HEADER -->
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h1>Reviews Management</h1>
      <p class="text-muted">
        Manage and moderate all user reviews
      </p>
    </div>

    <a href="/admin/dashboard" class="btn btn-dark">
      ⬅ Back to Dashboard
    </a>
  </div>

  <hr />

  <!-- EMPTY STATE -->
  <% if (reviews.length === 0) { %>

    <div class="alert alert-info">
      No reviews found.
    </div>

  <% } %>

  <!-- REVIEWS GRID -->
  <div class="row">

    <% reviews.forEach(review => { %>

      <div class="col-md-6 mb-4">

        <div class="card shadow-sm h-100">

          <div class="card-body">

            <!-- AUTHOR -->
            <h5 class="card-title">
              👤 <%= review.author?.username || "Unknown User" %>
            </h5>
            <!-- LISTING -->
<p class="mb-2">
  🏠 Listing:
  <strong>
    <%= review.listing?.title || "Deleted Listing" %>
  </strong>
</p>
            <!-- RATING -->
            <p class="mb-2">
              ⭐ Rating:
              <strong><%= review.rating %>/5</strong>
            </p>

            <!-- COMMENT -->
            <p class="card-text">
              <%= review.comment %>
            </p>

            <!-- DATE -->
            <p class="text-muted small">
              <%= review.created_at.toDateString() %>
            </p>

            <hr />

            <!-- DELETE BUTTON -->
            <form
              method="POST"
              action="/admin/reviews/<%= review._id %>?_method=DELETE"
            >
              <button class="btn btn-danger btn-sm">
                Delete Review
              </button>
            </form>

          </div>

        </div>

      </div>

    <% }) %>

  </div>

</div>