<h1>Users Management</h1>

<p style="color:#666;">View and manage all registered users</p>

<a href="/admin/dashboard">⬅ Back to Dashboard</a>

<hr />

<div style="overflow-x:auto; margin-top:15px;">

  <table style="
    width:100%;
    border-collapse: collapse;
    background:#fff;
    border-radius:10px;
    overflow:hidden;
    box-shadow:0 2px 8px rgba(0,0,0,0.05);
  ">

    <thead>
      <tr style="background:#f3f4f6; text-align:left;">
        <th style="padding:10px;">Username</th>
        <!-- <th style="padding:10px;">Email</th> -->
        <th style="padding:10px;">Role</th>
        <th style="padding:10px;">Listings</th>
        <th style="padding:10px;">Status</th>
        <th style="padding:10px;">Actions</th>
      </tr>
    </thead>

    <tbody>
      <% userData.forEach(data => { %>
        <tr style="border-bottom:1px solid #eee;">

          <!-- Username -->
          <td style="padding:10px;">
            <%= data.user.username %>
          </td>

          <!-- Email -->
          <!-- <td style="padding:10px; color:#555;">
            <%= data.user.username %>@mail.com
          </td> -->

          <!-- Role -->
          <td style="padding:10px;">
            <% if (data.user.isAdmin) { %>
              <span style="background:#22c55e; color:white; padding:4px 8px; border-radius:6px;">
                Admin
              </span>
            <% } else { %>
              <span style="background:#facc15; padding:4px 8px; border-radius:6px;">
                User
              </span>
            <% } %>
          </td>

          <!-- Listings -->
          <td style="padding:10px;">
            <%= data.listingsCount %>
          </td>

          <!-- Status -->
          <td style="padding:10px;">
            <% if (data.user.isBlocked) { %>
              <span style="background:#ef4444; color:white; padding:4px 8px; border-radius:6px;">
                Blocked
              </span>
            <% } else { %>
              <span style="background:#22c55e; color:white; padding:4px 8px; border-radius:6px;">
                Active
              </span>
            <% } %>
          </td>
          <td style="padding:10px;">

  <% if (data.user.isBlocked) { %>

    <!-- UNBLOCK -->
    <form method="POST" action="/admin/users/<%= data.user._id %>/unblock" style="display:inline;">
      <button style="
        background:#22c55e;
        color:white;
        border:none;
        padding:5px 8px;
        border-radius:6px;
        cursor:pointer;
      ">
        Unblock
      </button>
    </form>

  <% } else { %>

    <!-- BLOCK -->
    <form method="POST" action="/admin/users/<%= data.user._id %>/block" style="display:inline;">
      <button style="
        background:#ef4444;
        color:white;
        border:none;
        padding:5px 8px;
        border-radius:6px;
        cursor:pointer;
      ">
        Block
      </button>
    </form>

  <% } %>

</td>

        </tr>
      <% }) %>
    </tbody>

  </table>

</div>